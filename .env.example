# Copiar este archivo a `.env` y completar con los valores reales del entorno.
# `.env` está en .gitignore — nunca subir secretos al repo.

# ─── Servidor ─────────────────────────────────────────────────
PORT=4000

# ─── Base de datos (MySQL) ────────────────────────────────────
# Las 5 variables son obligatorias: configDataBase.ts lanza excepción si falta alguna.
DB_NAME=sigi_db
DB_USER_M=root
DB_PASSWORD=password
DB_HOST=localhost
DB_DIALECT_M=mysql

# ─── Autenticación ────────────────────────────────────────────
# Usado por auth.controller.ts para firmar el JWT.
# Si se omite, se usa el fallback "secret_key_provisoria" (NO usar en producción).
JWT_SECRET=cambiar_en_produccion
# Duración del token en segundos. Si se omite, default = 8 hs (28800).
JWT_EXPIRES_IN=28800

# ─── Email (nodemailer, para notificaciones) ─────────────────
# Cuenta Gmail desde la que se envían los emails y "App Password"
# (no la contraseña real de Gmail). Ver:
# https://support.google.com/accounts/answer/185833
USER_GMAIL=usuario@gmail.com
PASS_APP=app_password_de_16_caracteres

# ─── Recuperación de contraseña ───────────────────────────────
# Base URL del frontend, usada para armar el link del email de
# recuperación: ${FRONT_URL}/restablecer-contrasenia/<token>.
# Si se omite, default = http://localhost:5173 (dev).
FRONT_URL=http://localhost:5173

# ─── Entorno ──────────────────────────────────────────────────
# En "production" el error-handler oculta los mensajes detallados de error.
NODE_ENV=development

# ─── Flags opcionales del script de seed (scripts/db-setup.ts) ─
# SEED_FORCE=false   → no resetea la DB (default: la resetea)
# SEED_ONLY=true     → solo corre seeds, no recrea esquema
